# ==========================================

frontend/node_modules/

frontend/dist/

frontend/.vite/

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# React Environment
# ==========================================

frontend/.env
frontend/.env.*

# ==========================================
