var/
wheels/

*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
env/
ENV/

# ==========================================
# Environment Variables
# ==========================================

.env
.env.*

# ==========================================
# Database
# ==========================================

*.db
*.sqlite3

# ==========================================
